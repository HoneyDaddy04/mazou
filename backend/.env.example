# Database — SQLite for dev, PostgreSQL for prod
# Dev (default):
DATABASE_URL=sqlite+aiosqlite:///./mazou.db
# Prod:
# DATABASE_URL=postgresql+asyncpg://mazou:mazou@localhost:5432/mazou

# Cache — "memory" for dev, "redis://localhost:6379/0" for prod
CACHE_URL=memory

# Auth
SECRET_KEY=change-me-in-production-use-a-real-secret

# Paystack (use test keys for dev)
PAYSTACK_SECRET_KEY=sk_test_xxx

# Provider API keys (add the ones you have)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=

# FX rate (NGN per 1 USD) — updated manually or via API in prod
FX_RATE_NGN_USD=1580

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# Mazou margin on managed mode (15% default)
MANAGED_MARGIN=0.15
